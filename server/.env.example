# ── Dexter Backend Environment ──
# Copy to .env and fill in values

# Server
DEXTER_HOST=0.0.0.0
DEXTER_PORT=8000

# Ollama (install: https://ollama.com)
DEXTER_OLLAMA_BASE_URL=http://localhost:11434
DEXTER_OLLAMA_MODEL=qwen2.5:32b
DEXTER_OLLAMA_EMBED_MODEL=nomic-embed-text
DEXTER_OLLAMA_FAST_MODEL=llama3.2:3b

# PostgreSQL (install + enable pgvector extension)
DEXTER_DATABASE_URL=postgresql://dexter:dexter@localhost:5432/dexter

# Voice (Phase 3)
DEXTER_WHISPER_MODEL=base
DEXTER_PIPER_VOICE_ORCH=en_US-lessac-medium
DEXTER_PIPER_VOICE_SHADOW=en_US-alan-medium

# Tools (Phase 2)
DEXTER_SEARXNG_URL=http://localhost:8888

# Notifications (Phase 4)
DEXTER_NTFY_TOPIC=dexter-gates
DEXTER_NTFY_SERVER=https://ntfy.sh

# Cloud APIs (Phase 5 — paid escalation, leave blank until needed)
DEXTER_ANTHROPIC_API_KEY=
DEXTER_OPENAI_API_KEY=
DEXTER_GROQ_API_KEY=

# Budget
DEXTER_DAILY_CLOUD_BUDGET=5.00
DEXTER_PER_TASK_BUDGET_DEFAULT=0.50
